<Window x:Class="DesktopPlus.UpdateActionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Loc.UpdateDialogTitle}"
        Width="560"
        MinWidth="520"
        MaxWidth="700"
        Height="280"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        KeyDown="Window_KeyDown">
    <Border CornerRadius="16"
            BorderThickness="1"
            BorderBrush="#3A4252"
            Background="#111720"
            SnapsToDevicePixels="True"
            MouseLeftButtonDown="RootBorder_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24"
                              ShadowDepth="0"
                              Opacity="0.45"
                              Color="#000000"/>
        </Border.Effect>

        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Width="26"
                        Height="26"
                        CornerRadius="13"
                        Background="#2A3550"
                        BorderBrush="#4A6CAD"
                        BorderThickness="1">
                    <TextBlock Text="U"
                               Foreground="#CFE2FF"
                               FontSize="14"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <TextBlock Grid.Column="1"
                           Margin="10,0,0,0"
                           Text="{DynamicResource Loc.UpdateDialogTitle}"
                           Foreground="#F3F6FB"
                           FontSize="17"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </Grid>

            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        CornerRadius="10"
                        BorderThickness="1"
                        BorderBrush="#33405A"
                        Background="#1A2332"
                        Padding="12,9">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Loc.UpdateDialogInstalledLabel}"
                                   Foreground="#9FB1CC"
                                   FontSize="12"/>
                        <TextBlock x:Name="InstalledVersionText"
                                   Margin="0,3,0,0"
                                   Foreground="#EEF4FF"
                                   FontSize="16"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        CornerRadius="10"
                        BorderThickness="1"
                        BorderBrush="#3C5D92"
                        Background="#1E2B41"
                        Padding="12,9">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Loc.UpdateDialogLatestLabel}"
                                   Foreground="#AEC6EA"
                                   FontSize="12"/>
                        <TextBlock x:Name="LatestVersionText"
                                   Margin="0,3,0,0"
                                   Foreground="#F8FBFF"
                                   FontSize="16"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock Grid.Row="2"
                       Text="{DynamicResource Loc.UpdateDialogChooseAction}"
                       Foreground="#95A7C2"
                       FontSize="12"
                       VerticalAlignment="Top"/>

            <Grid Grid.Row="3" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="{DynamicResource Loc.UpdateDialogOpenReleaseButton}"
                        Height="40"
                        Background="#232D3F"
                        BorderBrush="#3D4C65"
                        BorderThickness="1"
                        Foreground="#E4ECF9"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="OpenReleaseButton_Click"/>

                <Button Grid.Column="2"
                        Content="{DynamicResource Loc.UpdateDialogInstallNowButton}"
                        Height="40"
                        Background="#3E6DE0"
                        BorderBrush="#5A83E8"
                        BorderThickness="1"
                        Foreground="White"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        IsDefault="True"
                        Click="InstallNowButton_Click"/>

                <Button Grid.Column="4"
                        Content="{DynamicResource Loc.UpdateDialogLaterButton}"
                        Height="40"
                        Background="#1A202B"
                        BorderBrush="#303B4E"
                        BorderThickness="1"
                        Foreground="#C9D5E7"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        IsCancel="True"
                        Click="LaterButton_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>
